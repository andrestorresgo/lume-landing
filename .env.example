# Supabase Configuration
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# PayPal Sandbox Configuration
# Public client ID for rendering the buttons on the frontend (client side)
PUBLIC_PAYPAL_CLIENT_ID=your-paypal-sandbox-client-id

# Server-only client secret for calling Order create and capture REST APIs (MUST NEVER BE EXPOSED TO CLIENT)
PAYPAL_CLIENT_SECRET=your-paypal-sandbox-client-secret

# PayPal Environment - Hardcoded to "sandbox" for this school project
PUBLIC_PAYPAL_ENV=sandbox
