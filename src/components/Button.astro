---
// Styled by Tailwind :)
interface Props {
	class?: string;
	href?: string;
	target?: string;
	rel?: string;
}
const { 
	class: className = "text-white border-white/10 hover:bg-white/10 focus:ring-white/10",
	href,
	target,
	rel
} = Astro.props;

const Element = href ? 'a' : 'button';
---

<Element
	href={href}
	target={target}
	rel={rel}
	class={`custom-button appearance-none py-2.5 px-6 bg-transparent font-semibold rounded-none shadow-sm focus:outline-none focus:ring-1 border inline-block text-center ${className}`}
>
	<slot />
</Element>

<style>
  .custom-button {
    transition: transform 150ms cubic-bezier(0.23, 1, 0.32, 1), background-color 150ms ease, border-color 150ms ease;
  }
  
  .custom-button:active {
    transform: scale(0.97);
  }
</style>

