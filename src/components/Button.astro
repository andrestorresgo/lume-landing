---
// Click button, get confetti!
// Styled by Tailwind :)
---

<button
	class="appearance-none py-2 px-4 bg-transparent text-white font-semibold rounded-lg shadow-md hover:bg-white/10 focus:outline-none focus:ring-2 focus:ring-white/10 focus:ring-opacity-75 border border-white/10"
>
	<slot />
</button>

<script>
	import confetti from 'canvas-confetti';
	const button = document.body.querySelector('button');

	if (button) {
		button.addEventListener('click', () => confetti());
	}
</script>
