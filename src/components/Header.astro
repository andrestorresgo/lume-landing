---
import Button from "./Button.astro";
import HeaderAuthControls from "./HeaderAuthControls.tsx";

interface Props {
  activePath?: string;
  textColor?: string;
  logoColor?: string;
  activeColor?: string;
  hoverColor?: string;
  buttonClass?: string;
}

const {
  activePath = "/",
  textColor = "text-[#FBF9F6]",
  logoColor = "text-[#FBF9F6]",
  activeColor = "text-[#ff827a]",
  hoverColor = activeColor === "text-[#7C0A12]"
    ? "hover:text-[#7C0A12]"
    : "hover:text-[#ff827a]",
  buttonClass = "text-[#FBF9F6] border-[#FBF9F6]/20 hover:bg-[#FBF9F6]/10 focus:ring-[#FBF9F6]/20",
} = Astro.props;
---

<header
  class="absolute top-0 left-0 right-0 w-full flex items-center justify-between px-4 py-6 md:px-8 z-50 nav-font"
>
  <div class="flex-1">
    <a
      href="/"
      class={`logo-link font-heading text-2xl tracking-tighter transition-opacity ${logoColor} hover:opacity-80`}
    >
      LUMÉ
    </a>
  </div>

  <nav class="hidden md:block flex-1">
    <ul
      class={`flex gap-10 justify-center text-[10px] md:text-xs uppercase tracking-widest font-semibold ${textColor}`}
    >
      <li>
        <a
          href="/"
          class={`nav-link ${activePath === "/" ? "active " + activeColor : ""} ${hoverColor}`}
        >
          Inicio
        </a>
      </li>
      <li>
        <a
          href="/colecciones"
          class={`nav-link ${activePath === "/colecciones" ? "active " + activeColor : ""} ${hoverColor}`}
        >
          Colecciones
        </a>
      </li>
      <li>
        <a
          href="/sobre-nosotros"
          class={`nav-link ${activePath === "/sobre-nosotros" ? "active " + activeColor : ""} ${hoverColor}`}
        >
          Sobre nosotros
        </a>
      </li>
      <li>
        <span class={`nav-link cursor-pointer ${hoverColor}`}> Contacto </span>
      </li>
    </ul>
  </nav>

  <div class="flex-1 flex justify-end items-center gap-4 md:gap-6">
    <Button
      href="https://wa.me/59175799191?text=Hola,%20me%20gustaria%20obtener%20más%20información%20sobre%20sus%20productos"
      target="_blank"
      rel="noopener noreferrer"
      class={`text-[10px] uppercase tracking-widest ${buttonClass}`}
    >
      Contactanos
    </Button>
    <HeaderAuthControls client:load buttonClass={buttonClass} textColor={textColor} hoverColor={hoverColor} />
  </div>
</header>

<style>
  .nav-font {
    font-family:
      "Inter",
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      "Helvetica Neue",
      Arial,
      sans-serif;
  }

  .font-heading {
    font-family:
      "Playfair Display", Georgia, Cambria, "Times New Roman", Times, serif;
  }

  .logo-link {
    display: inline-block;
    transition:
      opacity 200ms ease,
      transform 150ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  .logo-link:active {
    transform: scale(0.97);
  }

  .nav-link {
    position: relative;
    padding-bottom: 4px;
    transition: color 200ms cubic-bezier(0.23, 1, 0.32, 1);
    display: inline-block;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: currentColor;
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 250ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  .nav-link.active::after,
  .nav-link:hover::after {
    transform: scaleX(1);
  }
</style>
