---
import '../styles/global.css';
// Component Imports
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import background from '../assets/background.webp';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import SEOMeta from '../components/SEOMeta.astro';

const homepageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://lume-landing-murex.vercel.app/#website",
      "url": "https://lume-landing-murex.vercel.app/",
      "name": "LUMÉ",
      "description": "Joyería de intención y diseño hecha a mano con piedras naturales y metales nobles.",
      "publisher": {
        "@id": "https://lume-landing-murex.vercel.app/#organization"
      },
      "inLanguage": "es"
    },
    {
      "@type": "Organization",
      "@id": "https://lume-landing-murex.vercel.app/#organization",
      "name": "LUMÉ Jewelry",
      "url": "https://lume-landing-murex.vercel.app/",
      "logo": {
        "@type": "ImageObject",
        "url": "https://lume-landing-murex.vercel.app/apple-touch-icon.png"
      }
    }
  ]
};
---

<html lang="es">
	<head>
		<GoogleAnalytics measurementId="G-JK7FNYNZ5R" />
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		
		<SEOMeta 
			title="LUMÉ - Joyería de Intención y Diseño Hecha a Mano"
			description="Descubre piezas únicas de joyería hechas a mano con gemas naturales seleccionadas para acompañarte en tu día a día. Cuarzo, ojo de tigre y roca volcánica con plata y oro."
			schema={homepageSchema}
		/>
		
		<!-- Google Fonts for Editorial Aesthetic -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet" />
	</head>

	<body class="bg-gray-50 dark:bg-zinc-950 font-sans antialiased overflow-x-hidden min-h-screen bg-cover bg-center bg-no-repeat" style={`background-image: url('${background.src}')`}>
		<Header />
		<!-- TODO: research better blur effect -->
		<main class="backdrop-blur-3xl mask-to-t">
			<Hero />
		</main>
	</body>
</html>

<style is:global>
	/* Page-specific font-family overrides to align with Stitch Luminous design */
	.font-heading {
		font-family: 'Playfair Display', Georgia, Cambria, "Times New Roman", Times, serif !important;
	}
	
	.font-sans {
		font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif !important;
	}
</style>
