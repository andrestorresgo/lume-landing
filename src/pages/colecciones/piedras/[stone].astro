---
import '../../../styles/global.css';
import Header from '../../../components/Header.astro';
import CollectionsPage from '../../../components/CollectionsPage.tsx';
import placeholderBackground from '../../../assets/background.webp';
import GoogleAnalytics from '../../../components/GoogleAnalytics.astro';
import SEOMeta from '../../../components/SEOMeta.astro';
import mockData from '../../../data/mockData.json';
import seoData from '../../../data/seoData.json';

export async function getStaticPaths() {
  return Object.keys(seoData.stones).map(stoneKey => ({
    params: { stone: stoneKey },
    props: { stoneKey }
  }));
}

const { stone } = Astro.params;
const { stoneKey } = Astro.props;

const seoInfo = seoData.stones[stoneKey];
const filteredProducts = mockData.products.filter(p => p.stone === seoInfo.name);

const collectionsSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": seoInfo.title,
  "description": seoInfo.metaDescription,
  "url": `https://lume-landing-murex.vercel.app/colecciones/piedras/${stone}`,
  "numberOfItems": filteredProducts.length,
  "itemListElement": filteredProducts.map((product, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "item": {
      "@type": "Product",
      "name": product.name,
      "description": product.description,
      "offers": {
        "@type": "Offer",
        "price": product.price.toString(),
        "priceCurrency": "BOB",
        "availability": "https://schema.org/InStock"
      }
    }
  }))
};
---

<html lang="es">
	<head>
		<GoogleAnalytics measurementId="G-JK7FNYNZ5R" />
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		
		<SEOMeta 
			title={seoInfo.title}
			description={seoInfo.metaDescription}
			canonicalPath={`/colecciones/piedras/${stone}`}
			schema={collectionsSchema}
		/>
		
		<!-- Google Fonts for Editorial Aesthetic -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet" />
	</head>

	<body class="bg-[#fbf9f6] text-[#1C1917] font-sans antialiased min-h-screen overflow-x-hidden">
		<Header 
			activePath="/colecciones" 
			textColor="text-[#1C1917]" 
			logoColor="text-[#1C1917]" 
			activeColor="text-[#7C0A12]"
			buttonClass="text-[#1C1917] border-[#1C1917]/20 hover:bg-[#1C1917]/5 focus:ring-[#1C1917]/10"
		/>
		
		<main>
			<CollectionsPage 
				client:load 
				placeholderImage={placeholderBackground.src} 
				initialStone={seoInfo.name}
				customHeroTitle={seoInfo.heroTitle}
				customHeroDescription={seoInfo.heroDescription}
				customPretitle="Piedra de Intención"
			/>

			<!-- Rich Content Section to Prevent Thin Content -->
			<section class="max-w-4xl mx-auto px-6 md:px-16 py-16 border-t border-[#78716C]/10 text-center flex flex-col items-center gap-6 mt-12">
				<span class="text-xs uppercase tracking-widest text-[#7C0A12] font-semibold">El Significado de las Gemas</span>
				<h2 class="font-heading text-3xl text-[#1C1917]">Sobre el {seoInfo.name} y su Energía</h2>
				<div class="w-10 h-0.5 bg-[#7C0A12]/30 mb-2"></div>
				<p class="text-sm md:text-base text-[#625d5b] leading-relaxed font-light text-pretty max-w-3xl">
					{seoInfo.longCopy}
				</p>
				
				<!-- Hub and Spoke Interlinking -->
				<div class="flex flex-col gap-2 mt-8">
					<span class="text-[10px] uppercase tracking-widest text-[#78716C]/70">Explorar Otras Gemas de la Colección</span>
					<div class="flex flex-wrap justify-center gap-x-6 gap-y-2 mt-2">
						{Object.keys(seoData.stones).filter(s => s !== stone).map(s => (
							<a href={`/colecciones/piedras/${s}`} class="text-xs uppercase tracking-widest text-[#7C0A12] font-semibold hover:text-[#560006] transition-colors duration-300">
								{seoData.stones[s].name}
							</a>
						))}
					</div>
				</div>
			</section>
		</main>

		<!-- Footer section matching editorial style -->
		<footer class="bg-[#fbf9f6] w-full py-16 border-t border-[#78716C]/25 mt-12">
			<div class="flex flex-col items-center gap-6 px-8 max-w-7xl mx-auto">
				<a class="font-heading text-3xl text-[#1C1917] tracking-tighter" href="/">LUMÉ</a>
				<nav class="flex flex-wrap justify-center gap-6 md:gap-12 text-sm text-[#78716C] uppercase tracking-wider font-semibold">
					<a class="hover:text-[#7C0A12] transition-colors duration-300" href="#">Privacidad</a>
					<a class="hover:text-[#7C0A12] transition-colors duration-300" href="#">Términos</a>
					<a class="hover:text-[#7C0A12] transition-colors duration-300" href="#">Envíos</a>
					<a class="hover:text-[#7C0A12] transition-colors duration-300" href="#">Cuidado de Piezas</a>
				</nav>
				<p class="text-[10px] text-[#78716C]/60 mt-4 uppercase tracking-widest">
					© 2026 LUMÉ Jewelry. Hecho a mano.
				</p>
			</div>
		</footer>
	</body>
</html>

<style is:global>
	.font-heading {
		font-family: 'Playfair Display', Georgia, Cambria, "Times New Roman", Times, serif !important;
	}
	
	.font-sans {
		font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif !important;
	}
</style>
